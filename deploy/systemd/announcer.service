[Unit]
Description=Announcer FastAPI service
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/announcer-project-main
EnvironmentFile=/home/ubuntu/announcer-project-main/.env
ExecStart=/home/ubuntu/announcer-project-main/.venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
